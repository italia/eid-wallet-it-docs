{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/italia/eid-wallet-it-docs/handbooks/it/authentic-sources/json-schemas/schema-validazione-form-onboarding-fonte-autentica.schema.json",
  "$version": "1.1.1",
  "title": "Schema validazione Fonte Autentica",
  "description": "Schema di validazione per progettazione-caratteristiche-eaa.json. Ordine sezioni: metadata, casi d'uso, pdnd metadata, request, data model, mappatura errori, mappatura stati, assistenza.",
  "type": "object",
  "required": [
    "metadata",
    "casi d'uso",
    "pdnd metadata",
    "request",
    "data model",
    "mappatura errori",
    "mappatura stati",
    "assistenza"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "required": [
        "nome ente titolare",
        "nome eaa"
      ],
      "properties": {
        "nome ente titolare": {
          "type": "string",
          "minLength": 1,
          "description": "Nome ufficiale dell'Ente titolare, es. MIT - Direzione generale per la Motorizzazione"
        },
        "nome eaa": {
          "type": "string",
          "minLength": 1,
          "description": "Nome ufficiale dell'EAA, es. Patente di guida"
        },
        "versione": {
          "type": "string"
        },
        "readonly": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Elenco opzionale dei campi allo stesso livello da considerare non modificabili."
        }
      },
      "title": "Denominazioni ufficiali per Ente e EAA"
    },
    "pdnd metadata": {
      "type": "object",
      "required": [
        "pdnd eservice id prod",
        "pdnd eservice id uat",
        "pdnd eservice name",
        "token type",
        "audit_rest_02_richiesto"
      ],
      "properties": {
        "pdnd eservice id prod": {
          "type": "string",
          "description": "UUID e-service PDND ambiente di produzione"
        },
        "pdnd eservice id uat": {
          "type": "string",
          "description": "UUID e-service PDND ambiente UAT/collaudo"
        },
        "pdnd eservice name": {
          "type": "string",
          "description": "Denominazione e-service su PDND"
        },
        "token type": {
          "type": "string",
          "description": "Tipo token di accesso (es. Bearer)"
        },
        "audit_rest_02_richiesto": {
          "type": "boolean",
          "description": "Indica se è richiesta conformità audit REST 02 (PDND)"
        }
      }
    },
    "request": {
      "type": "object",
      "required": [
        "parametri input"
      ],
      "properties": {
        "parametri input": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parametro_input"
          }
        }
      }
    },
    "data model": {
      "type": "object",
      "required": [
        "versione",
        "dataset"
      ],
      "description": "Contratto della response dell'endpoint Fonte Autentica (campi del dataset restituito)",
      "properties": {
        "versione": {
          "type": "string",
          "description": "Versione del contratto di response (es. 1.0, 1.1)"
        },
        "dataset": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/data_model_campo"
          }
        },
        "readonly": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Elenco opzionale dei campi allo stesso livello da considerare non modificabili."
        }
      },
      "title": "Data Model"
    },
    "mappatura errori": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mappatura_errore"
      },
      "title": "Mappatura errori",
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 200
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 400
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 401
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 404
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 429
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 500
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 503
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "mappatura stati": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mappatura_stato"
      },
      "title": "Mappatura stati"
    },
    "lista nome campo": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lista_nome_campo_riga"
      }
    },
    "assistenza": {
      "type": "object",
      "required": [
        "referenti",
        "canali",
        "faq",
        "testi informativi"
      ],
      "properties": {
        "referenti": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/referente_assistenza"
          },
          "prefixItems": [
            {
              "allOf": [
                {
                  "$ref": "#/$defs/referente_assistenza"
                },
                {
                  "properties": {
                    "ruolo": {
                      "const": "Referente ambito sistemistico"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/referente_assistenza"
                },
                {
                  "properties": {
                    "ruolo": {
                      "const": "Referente ambito applicativo"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/referente_assistenza"
                },
                {
                  "properties": {
                    "ruolo": {
                      "const": "Referente ambito assistenza"
                    }
                  }
                }
              ]
            }
          ]
        },
        "canali": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/canale_assistenza"
          }
        },
        "faq": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/faq_item"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/campo_risposta"
              }
            }
          ]
        },
        "testi informativi": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/testo_informativo_item"
          }
        }
      }
    },
    "casi d'uso": {
      "$ref": "#/$defs/casi_d_uso"
    }
  },
  "$defs": {
    "data_model_campo": {
      "type": "object",
      "required": [
        "attestazione",
        "parametro",
        "descrizione",
        "nome campo",
        "esempio campo compilato",
        "obbligatorio",
        "tipologia",
        "lunghezza massima caratteri",
        "note"
      ],
      "properties": {
        "attestazione": {
          "type": "string"
        },
        "parametro": {
          "type": "string"
        },
        "descrizione": {
          "type": "string"
        },
        "nome campo": {
          "type": "string"
        },
        "esempio campo compilato": {
          "type": "string"
        },
        "obbligatorio": {
          "type": "boolean",
          "description": "true se il campo è obbligatorio nella response; false se opzionale"
        },
        "tipologia": {
          "type": "string"
        },
        "lunghezza massima caratteri": {
          "type": "integer",
          "minimum": 0,
          "description": "Lunghezza massima in caratteri (intero senza segno)"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "parametro_input": {
      "type": "object",
      "required": [
        "nome parametro",
        "descrizione",
        "nome campo",
        "esempio campo compilato",
        "obbligatorio",
        "tipologia",
        "lunghezza massima caratteri",
        "valori ammessi",
        "note"
      ],
      "properties": {
        "nome parametro": {
          "type": "string"
        },
        "descrizione": {
          "type": "string"
        },
        "nome campo": {
          "type": "string"
        },
        "esempio campo compilato": {
          "type": "string"
        },
        "obbligatorio": {
          "type": "boolean",
          "description": "true se il parametro è obbligatorio in input; false se opzionale"
        },
        "tipologia": {
          "type": "string"
        },
        "lunghezza massima caratteri": {
          "type": "integer",
          "minimum": 0,
          "description": "Lunghezza massima in caratteri (intero senza segno)"
        },
        "note": {
          "type": "string"
        },
        "valori ammessi": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Valori ammessi come elenco (es. enum)"
        }
      }
    },
    "mappatura_errore": {
      "type": "object",
      "required": [
        "codice",
        "esito",
        "applicabile",
        "causa",
        "azione utente",
        "note"
      ],
      "properties": {
        "codice": {
          "type": "integer",
          "minimum": 0,
          "description": "Codice HTTP o di dominio (es. 200, 404, 540). Obbligatorietà di applicabile vincolata da allOf sotto."
        },
        "esito": {
          "type": "string"
        },
        "applicabile": {
          "type": "boolean",
          "description": "true per codici obbligatori (200, 400, 401, 404, 429, 500, 503); false per codici opzionali (403, 405, 406, 408, 409, 410, 413, 414, 421, 431, 451, 501, 540, 541)."
        },
        "causa": {
          "type": "string",
          "description": "Causa dell'errore"
        },
        "azione utente": {
          "type": "string",
          "description": "Messaggio per l'utente in caso di errore"
        },
        "note": {
          "type": "string"
        },
        "readonly": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "codice": {
                "enum": [
                  200,
                  400,
                  401,
                  404,
                  429,
                  500,
                  503
                ]
              }
            },
            "required": [
              "codice"
            ]
          },
          "then": {
            "properties": {
              "applicabile": {
                "const": true
              }
            }
          }
        }
      ]
    },
    "mappatura_stato": {
      "type": "object",
      "required": [
        "stato",
        "descrizione",
        "applicabile",
        "azione utente",
        "messaggio",
        "note"
      ],
      "properties": {
        "stato": {
          "type": "string",
          "enum": [
            "Valido",
            "Non valido",
            "Sospeso"
          ]
        },
        "descrizione": {
          "type": "string",
          "description": "Causa del cambiamento di stato"
        },
        "applicabile": {
          "type": "boolean",
          "description": "true se lo stato si applica a questo EAA; false altrimenti"
        },
        "azione utente": {
          "type": "string",
          "description": "Messaggio per l'utente"
        },
        "messaggio": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "readonly": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "lista_nome_campo_riga": {
      "type": "object",
      "required": [
        "categoria",
        "parametro",
        "nome campo",
        "descrizione"
      ],
      "properties": {
        "categoria": {
          "type": "string"
        },
        "parametro": {
          "type": "string"
        },
        "nome campo": {
          "type": "string"
        },
        "descrizione": {
          "type": "string"
        }
      }
    },
    "campo_risposta": {
      "type": "object",
      "required": [
        "domanda",
        "risposta"
      ],
      "properties": {
        "domanda": {
          "type": "string"
        },
        "suggerimento": {
          "type": "string"
        },
        "risposta": {
          "type": "string"
        }
      }
    },
    "canale_assistenza": {
      "type": "object",
      "required": [
        "tipo",
        "dettaglio canale",
        "note"
      ],
      "properties": {
        "tipo": {
          "type": "string",
          "enum": [
            "Email assistenza",
            "Numero telefonico",
            "Altro"
          ],
          "description": "Tipo di canale"
        },
        "note": {
          "type": "string"
        },
        "dettaglio canale": {
          "type": "string",
          "description": "testo visualizzato dall'utente"
        },
        "esempio": {
          "type": "string"
        },
        "readonly": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "if": {
        "properties": {
          "tipo": {
            "const": "Email assistenza"
          }
        },
        "required": [
          "tipo"
        ]
      },
      "then": {
        "properties": {
          "dettaglio canale": {
            "oneOf": [
              {
                "type": "string",
                "maxLength": 0
              },
              {
                "type": "string",
                "minLength": 1,
                "format": "email"
              }
            ]
          }
        }
      }
    },
    "campo_booleano": {
      "type": "object",
      "required": [
        "domanda",
        "risposta"
      ],
      "properties": {
        "domanda": {
          "type": "string"
        },
        "suggerimento": {
          "type": "string"
        },
        "risposta": {
          "type": "boolean"
        }
      }
    },
    "referente_assistenza": {
      "type": "object",
      "required": [
        "ruolo",
        "nome",
        "cognome",
        "email",
        "telefono"
      ],
      "properties": {
        "ruolo": {
          "type": "string"
        },
        "nome": {
          "type": "string"
        },
        "cognome": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "oneOf": [
            {
              "maxLength": 0
            },
            {
              "minLength": 1,
              "format": "email"
            }
          ]
        },
        "telefono": {
          "type": "string",
          "oneOf": [
            {
              "maxLength": 0
            },
            {
              "minLength": 4,
              "pattern": "^[0-9+\\-\\s()]+$",
              "maxLength": 25
            }
          ]
        },
        "readonly": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "faq_item": {
      "type": "object",
      "required": [
        "domanda",
        "risposta"
      ],
      "properties": {
        "domanda": {
          "type": "string"
        },
        "risposta": {
          "type": "string"
        }
      }
    },
    "target_utenti": {
      "type": "object",
      "required": [
        "presenza doc preesistente"
      ],
      "properties": {
        "presenza doc preesistente": {
          "$ref": "#/$defs/campo_booleano"
        },
        "utenti doc preesistente ": {
          "$ref": "#/$defs/campo_risposta"
        },
        "utenti doc preesistente eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "utenti eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "documento fisico preesistente": {
          "$ref": "#/$defs/campo_booleano"
        },
        "chi puo richiedere": {
          "$ref": "#/$defs/campo_risposta"
        },
        "prerequisiti": {
          "$ref": "#/$defs/campo_risposta"
        },
        "volume rilascio": {
          "$ref": "#/$defs/campo_risposta"
        },
        "limitazioni estensioni": {
          "$ref": "#/$defs/campo_risposta"
        }
      }
    },
    "emissione_formato": {
      "type": "object",
      "required": [
        "prerequisiti eaa",
        "catalogo o touchpoint eaa",
        "modalita sincrona differita eaa",
        "eaa multipla o singola",
        "identificazione utente"
      ],
      "properties": {
        "prerequisiti eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "prerequisiti possesso doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "canali richiesta  doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "formato doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "volume rilascio doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "richieste fisico vs digitale  doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "variazioni dati doc preesistente eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "variazioni dati doc preesistente eaa dettagli": {
          "$ref": "#/$defs/campo_risposta"
        },
        "catalogo o touchpoint eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "modalita sincrona differita eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "eaa multipla o singola": {
          "$ref": "#/$defs/campo_booleano"
        },
        "dominio": {
          "$ref": "#/$defs/campo_risposta"
        },
        "interesse pubblico": {
          "$ref": "#/$defs/campo_booleano"
        },
        "interesse pubblico motivazione": {
          "$ref": "#/$defs/campo_risposta"
        },
        "canali richiesta": {
          "$ref": "#/$defs/campo_risposta"
        },
        "richieste fisico vs digitale": {
          "$ref": "#/$defs/campo_risposta"
        },
        "formato attuale": {
          "$ref": "#/$defs/campo_risposta"
        },
        "dettagli digitale": {
          "$ref": "#/$defs/campo_risposta"
        },
        "possesso documento": {
          "$ref": "#/$defs/campo_booleano"
        },
        "possesso documento condizioni": {
          "$ref": "#/$defs/campo_risposta"
        },
        "catalogo o touchpoint": {
          "$ref": "#/$defs/campo_risposta"
        },
        "modalita sincrona differita": {
          "$ref": "#/$defs/campo_risposta"
        },
        "variazioni dati": {
          "$ref": "#/$defs/campo_risposta"
        },
        "eaa univoca": {
          "$ref": "#/$defs/campo_booleano"
        },
        "identificazione utente": {
          "$ref": "#/$defs/campo_booleano"
        },
        "identificazione utente motivazione": {
          "$ref": "#/$defs/campo_risposta"
        }
      }
    },
    "utilizzo": {
      "type": "object",
      "required": [
        "dominio eaa",
        "interesse pubblico eaa",
        "interesse pubblico motivazione eaa"
      ],
      "properties": {
        "dominio eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "interesse pubblico eaa": {
          "$ref": "#/$defs/campo_booleano"
        },
        "interesse pubblico motivazione eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "casi d uso doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "casi d uso doc preesistente eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "soggetti verificatori doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "modalita verifica doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "strumenti verifica doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "durata utilizzo doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "duarata validita doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "validita territoriale doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "validita territoriale doc preesistente eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "rinnovo doc preesistente": {
          "$ref": "#/$defs/campo_booleano"
        },
        "modalita rinnovo doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
        },
        "casi d uso eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "durata utilizzo eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "validita territoriale eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "contesti uso": {
          "$ref": "#/$defs/campo_risposta"
        },
        "soggetti verificatori": {
          "$ref": "#/$defs/campo_risposta"
        },
        "verifica validita": {
          "$ref": "#/$defs/campo_risposta"
        },
