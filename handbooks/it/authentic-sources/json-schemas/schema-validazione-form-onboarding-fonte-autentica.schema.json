{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/italia/eid-wallet-it-docs/handbooks/it/authentic-sources/json-schemas/schema-validazione-form-onboarding-fonte-autentica.schema.json",
  "$version": "2.0.0",
  "title": "Schema validazione Fonte Autentica",
  "description": "Schema di validazione per la compilazione del json form dedicato alla progettazione delle risorse EAA prodotte dalle Fonti Autentiche.",
  "type": "object",
  "required": [
    "denominazioni ufficiali",
    "casi d'uso",
    "dataset",
    "mappatura errori",
    "mappatura stati",
    "assistenza"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "readOnly": true,
      "description": "Riferimento allo schema di validazione (valore tecnico, non modificabile)."
    },
    "denominazioni ufficiali": {
      "type": "object",
      "required": [
        "nome ente titolare",
        "nome eaa",
        "versione"
      ],
      "properties": {
        "nome ente titolare": {
          "type": "string",
          "description": "Nome ufficiale dell'Ente titolare, es. MIT - Direzione generale per la Motorizzazione"
        },
        "nome eaa": {
          "type": "string",
          "description": "Nome ufficiale dell'EAA, es. Patente di guida"
        },
        "versione": {
          "type": "string",
          "const": "2.0.0",
          "readOnly": true,
          "description": "Versione del template di progettazione (valore fisso; aggiornare lo schema se si incrementa il template)."
        }
      },
      "title": "Denominazioni ufficiali per Ente e EAA"
    },
    "casi d'uso": {
      "title": "Casi d'uso",
      "$ref": "#/$defs/casi_d_uso"
    },
    "dataset": {
      "type": "object",
      "title": "Dataset",
      "description": "Dataset relativo all'EAA: identificativo univoco, parametri di richiesta dell'e-service e dati di risposta restituiti. Si compila un dataset per ciascun modulo/EAA.",
      "required": [
        "dataset_id",
        "parametri di richiesta",
        "dati di risposta"
      ],
      "properties": {
        "dataset_id": {
          "type": "object",
          "title": "Dataset ID",
          "description": "Identificativo univoco del dataset definito dal Titolare di Fonte Autentica. Si consiglia un UUID oppure una stringa breve, descrittiva e priva di spazi in formato kebab-case per nomi composti (es. tesserino-medici).",
          "required": [
            "descrizione",
            "esempio campo compilato",
            "note"
          ],
          "properties": {
            "descrizione": {
              "type": "string"
            },
            "esempio campo compilato": {
              "type": "string"
            },
            "note": {
              "type": "string"
            }
          }
        },
        "parametri di richiesta": {
          "type": "array",
          "title": "Parametri di richiesta",
          "description": "Parametri in ingresso all'endpoint e-service Fonte Autentica. Ogni elemento segue `parametro_input`.",
          "items": {
            "$ref": "#/$defs/parametro_input"
          }
        },
        "dati di risposta": {
          "type": "array",
          "title": "Dati di risposta",
          "description": "Campi del dataset restituito dall'endpoint Fonte Autentica (contratto di response **1.0**). Ogni elemento segue `data_model_campo`.",
          "items": {
            "$ref": "#/$defs/data_model_campo"
          }
        }
      }
    },
    "mappatura errori": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mappatura_errore"
      },
      "title": "Mappatura errori",
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 200
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 400
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 401
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 404
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 429
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 500
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 503
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "mappatura stati": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/mappatura_stato"
            },
            {
              "properties": {
                "stato": {
                  "const": "Valido"
                },
                "descrizione": {
                  "const": "L'EAA è valido e può essere utilizzato"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/mappatura_stato"
            },
            {
              "properties": {
                "stato": {
                  "const": "Non Valido"
                },
                "descrizione": {
                  "const": "L'EAA non è più valido e dunque non può essere più utilizzato"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/mappatura_stato"
            },
            {
              "properties": {
                "stato": {
                  "const": "Sospeso"
                },
                "descrizione": {
                  "const": "L'EAA è sospeso e non può essere temporaneamente utilizzato"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/mappatura_stato"
            },
            {
              "properties": {
                "stato": {
                  "const": "Scaduto"
                },
                "descrizione": {
                  "const": "L'EAA ha superato la data di scadenza amministrativa e richiede rinnovo o nuova emissione"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/mappatura_stato"
            },
            {
              "properties": {
                "stato": {
                  "const": "Da aggiornare"
                },
                "descrizione": {
                  "const": "L'EAA contiene dei dati obsoleti che necessitano di essere aggiornati tramite un rinnovo o nuova emissione"
                }
              }
            }
          ]
        }
      ],
      "title": "Mappatura stati"
    },
    "assistenza": {
      "type": "object",
      "title": "Assistenza",
      "description": "Ordine di compilazione e presentazione: referenti, canali, FAQ, testi informativi.",
      "required": [
        "referenti",
        "canali",
        "faq",
        "testi informativi"
      ],
      "properties": {
        "referenti": {
          "title": "Referenti",
          "type": "array",
          "items": {
            "$ref": "#/$defs/referente_assistenza"
          },
          "prefixItems": [
            {
              "allOf": [
                {
                  "$ref": "#/$defs/referente_assistenza"
                },
                {
                  "properties": {
                    "ruolo": {
                      "const": "Referente ambito sistemistico"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/referente_assistenza"
                },
                {
                  "properties": {
                    "ruolo": {
                      "const": "Referente ambito applicativo"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/referente_assistenza"
                },
                {
                  "properties": {
                    "ruolo": {
                      "const": "Referente ambito assistenza"
                    }
                  }
                }
              ]
            }
          ]
        },
        "canali": {
          "title": "Canali",
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {
              "allOf": [
                {
                  "$ref": "#/$defs/canale_assistenza"
                },
                {
                  "properties": {
                    "tipo": {
                      "const": "Email assistenza"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/canale_assistenza"
                },
                {
                  "properties": {
                    "tipo": {
                      "const": "Numero telefonico"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/canale_assistenza"
                },
                {
                  "properties": {
                    "tipo": {
                      "const": "Altro"
                    }
                  }
                }
              ]
            }
          ]
        },
        "faq": {
          "title": "FAQ",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/faq_item"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/campo_risposta"
              }
            }
          ]
        },
        "testi informativi": {
          "title": "Testi informativi",
          "type": "array",
          "items": {
            "$ref": "#/$defs/testo_informativo_item"
          }
        }
      }
    }
  },
  "$defs": {
    "data_model_campo": {
      "type": "object",
      "required": [
        "parametro",
        "descrizione",
        "nome campo",
        "esempio campo compilato",
        "obbligatorio",
        "tipologia",
        "note"
      ],
      "properties": {
        "parametro": {
          "type": "string"
        },
        "descrizione": {
          "type": "string"
        },
        "nome campo": {
          "type": "string"
        },
        "esempio campo compilato": {
          "type": "string"
        },
        "obbligatorio": {
          "type": "boolean",
          "description": "true se il campo è obbligatorio nella response; false se opzionale"
        },
        "tipologia": {
          "type": "string",
          "enum": [
            "STRING",
            "NUMBER",
            "DATE",
            "DATETIME",
            "JSON",
            "BINARY",
            "BASE64",
            "ARRAY_STRING",
            "ARRAY_NUMBER",
            "ARRAY_DATE",
            "ARRAY_DATETIME",
            "ARRAY_JSON",
            "ARRAY_BINARY",
            "ARRAY_BASE64"
          ],
          "description": "Tipo di dato del campo restituito. Indica esclusivamente il formato del valore (non l'insieme dei valori leciti). Valori: STRING (testo), NUMBER (numero), DATE (data di calendario), DATETIME (data e ora), JSON (oggetto strutturato in formato JSON), BINARY (dato binario), BASE64 (dato binario codificato in Base64). Per gli elenchi usare i tipi ARRAY_<TIPO> (es. ARRAY_STRING, ARRAY_NUMBER, ARRAY_DATE, ARRAY_DATETIME, ARRAY_JSON, ARRAY_BINARY, ARRAY_BASE64), dove <TIPO> indica il tipo degli elementi."
        },
        "lunghezza massima caratteri": {
          "type": "integer",
          "minimum": 0,
          "description": "Lunghezza massima in caratteri quando il dato è serializzato come stringa (es. tipologie testuali). Opzionale: omettere se non applicabile al tipo di attributo; in compilazione si consiglia di valorizzarlo per i campi con limite noto."
        },
        "note": {
          "type": "string"
        }
      }
    },
    "parametro_input": {
      "type": "object",
      "required": [
        "nome parametro",
        "descrizione",
        "nome campo",
        "esempio campo compilato",
        "obbligatorio",
        "tipologia",
        "lunghezza massima caratteri",
        "valori ammessi",
        "note"
      ],
      "properties": {
        "nome parametro": {
          "type": "string"
        },
        "descrizione": {
          "type": "string"
        },
        "nome campo": {
          "type": "string"
        },
        "esempio campo compilato": {
          "type": "string"
        },
        "obbligatorio": {
          "type": "boolean",
          "description": "true se il parametro è obbligatorio in input; false se opzionale"
        },
        "tipologia": {
          "type": "string",
          "enum": [
            "STRING",
            "NUMBER",
            "DATE",
            "DATETIME",
            "JSON",
            "BINARY",
            "BASE64",
            "ARRAY_STRING",
            "ARRAY_NUMBER",
            "ARRAY_DATE",
            "ARRAY_DATETIME",
            "ARRAY_JSON",
            "ARRAY_BINARY",
            "ARRAY_BASE64"
          ],
          "description": "Tipo di dato del parametro. Indica esclusivamente il formato del valore; per vincolare l'insieme finito dei valori leciti (dominio chiuso/enumerato) usare invece `valori ammessi`. Valori: STRING (testo), NUMBER (numero), DATE (data di calendario), DATETIME (data e ora), JSON (oggetto strutturato in formato JSON), BINARY (dato binario), BASE64 (dato binario codificato in Base64). Per gli elenchi usare i tipi ARRAY_<TIPO> (es. ARRAY_STRING, ARRAY_NUMBER, ARRAY_DATE, ARRAY_DATETIME, ARRAY_JSON, ARRAY_BINARY, ARRAY_BASE64), dove <TIPO> indica il tipo degli elementi."
        },
        "lunghezza massima caratteri": {
          "type": "integer",
          "minimum": 0,
          "description": "Lunghezza massima in caratteri (intero senza segno)"
        },
        "note": {
          "type": "string"
        },
        "valori ammessi": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Insieme finito dei valori leciti del parametro (dominio chiuso/enumerato). Complementare a `tipologia`, che indica il solo formato: usare questo campo solo quando esiste un elenco predefinito di valori; lasciare l'array vuoto (`[]`) quando il dominio è libero."
        }
      }
    },
    "mappatura_errore": {
      "type": "object",
      "required": [
        "codice",
        "esito",
        "applicabile",
        "causa",
        "azione utente",
        "note"
      ],
      "properties": {
        "codice": {
          "type": "integer",
          "enum": [
            200,
            400,
            401,
            403,
            404,
            405,
            406,
            408,
            409,
            410,
            413,
            414,
            421,
            429,
            431,
            451,
            500,
            501,
            503,
            540,
            541
          ],
          "description": "Codice HTTP o di dominio ammesso nel template (coppia codice/applicabile fissata dallo schema)."
        },
        "esito": {
          "type": "string"
        },
        "applicabile": {
          "type": "boolean",
          "description": "Obbligatoriamente true se il codice è tra quelli obbligatori del template (200, 400, 401, 404, 429, 500, 503); obbligatoriamente false per qualsiasi altro codice ammesso dall'enum (codici opzionali o futuri aggiunti all'enum ma non nella lista obbligatoria)."
        },
        "causa": {
          "type": "string",
          "description": "Causa dell'errore"
        },
        "azione utente": {
          "type": "string",
          "description": "Messaggio per l'utente in caso di errore"
        },
        "note": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "codice": {
                "enum": [
                  200,
                  400,
                  401,
                  404,
                  429,
                  500,
                  503
                ]
              }
            },
            "required": [
              "codice"
            ]
          },
          "then": {
            "properties": {
              "applicabile": {
                "const": true
              }
            }
          },
          "else": {
            "properties": {
              "applicabile": {
                "const": false
              }
            }
          }
        }
      ]
    },
    "mappatura_stato": {
      "type": "object",
      "required": [
        "stato",
        "descrizione",
        "applicabile",
        "azione utente",
        "note"
      ],
      "properties": {
        "stato": {
          "type": "string",
          "enum": [
            "Valido",
            "Non Valido",
            "Sospeso",
            "Scaduto",
            "Da aggiornare"
          ],
          "description": "Valore letterale dello stato (valore canonico come in documentazione): Valido, Non Valido, Sospeso, Scaduto, Da aggiornare."
        },
        "descrizione": {
          "type": "string",
          "description": "Descrizione testuale fissa dello stato (vincolata dallo schema, non modificabile)."
        },
        "causa": {
          "type": "string",
          "description": "Dettaglio opzionale della causa del cambiamento di stato (campo di supporto alla compilazione)."
        },
        "applicabile": {
          "type": [
            "boolean",
            "null"
          ],
          "description": "true se lo stato si applica a questo EAA; false altrimenti; null in bozza non ancora compilata."
        },
        "azione utente": {
          "type": "string",
          "description": "Messaggio per l'utente"
        },
        "messaggio": {
          "type": "string",
          "description": "Testo informativo aggiuntivo per la soluzione IT-Wallet (opzionale; se assente o vuoto non viene esposto alcun messaggio dedicato oltre a descrizione/azione utente)."
        },
        "note": {
          "type": "string"
        }
      }
    },
    "campo_risposta": {
      "type": "object",
      "description": "Domanda, campo risposta (testo libero) ed esempio guida.",
      "required": [
        "domanda",
        "risposta",
        "esempio"
      ],
      "properties": {
        "domanda": {
          "type": "string",
          "description": "Testo della domanda",
          "propertyOrder": 10
        },
        "risposta": {
          "description": "Risposta dell'Ente: stringa di testo libero (vuota in bozza non ancora compilata).",
          "propertyOrder": 20,
          "type": "string"
        },
        "esempio": {
          "type": "string",
          "description": "Esempio di risposta compilata (guida per l'Ente)",
          "propertyOrder": 30
        }
      }
    },
    "campo_risposta_booleano": {
      "type": "object",
      "description": "Variante di campo_risposta per domande chiuse sì/no: la risposta è esclusivamente un booleano JSON (true/false) oppure null in bozza non ancora compilata; non è ammesso testo libero.",
      "required": [
        "domanda",
        "risposta",
        "esempio"
      ],
      "properties": {
        "domanda": {
          "type": "string",
          "description": "Testo della domanda",
          "propertyOrder": 10
        },
        "risposta": {
          "description": "Risposta dell'Ente: booleano (true/false) o null in bozza non ancora compilata. Non è ammesso testo libero.",
          "propertyOrder": 20,
          "type": [
            "boolean",
            "null"
          ]
        },
        "esempio": {
          "type": "string",
          "description": "Esempio di risposta compilata (guida per l'Ente)",
          "propertyOrder": 30
        }
      }
    },
    "canale_assistenza": {
      "type": "object",
      "required": [
        "tipo",
        "dettaglio canale"
      ],
      "properties": {
        "tipo": {
          "type": "string",
          "enum": [
            "Email assistenza",
            "Numero telefonico",
            "Altro"
          ],
          "description": "Tipo di canale"
        },
        "note": {
          "type": "string",
          "description": "Note aggiuntive sul canale (opzionale)."
        },
        "dettaglio canale": {
          "type": "string",
          "description": "testo visualizzato dall'utente"
        },
        "esempio": {
          "type": "string"
        }
      },
      "if": {
        "properties": {
          "tipo": {
            "const": "Email assistenza"
          }
        },
        "required": [
          "tipo"
        ]
      },
      "then": {
        "properties": {
          "dettaglio canale": {
            "oneOf": [
              {
                "type": "string",
                "maxLength": 0
              },
              {
                "type": "string",
                "minLength": 1,
                "format": "email"
              }
            ]
          }
        }
      }
    },
    "referente_assistenza": {
      "type": "object",
      "required": [
        "ruolo",
        "nome",
        "cognome",
        "email",
        "telefono"
      ],
      "properties": {
        "ruolo": {
          "type": "string"
        },
        "nome": {
          "type": "string"
        },
        "cognome": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "oneOf": [
            {
              "maxLength": 0
            },
            {
              "minLength": 1,
              "format": "email"
            }
          ]
        },
        "telefono": {
          "type": "string",
          "oneOf": [
            {
              "maxLength": 0
            },
            {
              "minLength": 4,
              "pattern": "^[0-9+\\-\\s()]+$",
              "maxLength": 25
            }
          ]
        }
      }
    },
    "faq_item": {
      "type": "object",
      "description": "Voce FAQ: stessa struttura di campo_risposta (domanda, risposta, esempio; risposta di testo libero).",
      "required": [
        "domanda",
        "risposta",
        "esempio"
      ],
      "properties": {
        "domanda": {
          "type": "string",
          "description": "Testo della domanda",
          "propertyOrder": 10
        },
        "risposta": {
          "description": "Risposta dell'Ente: stringa di testo libero (vuota in bozza non ancora compilata).",
          "propertyOrder": 20,
          "type": "string"
        },
        "esempio": {
          "type": "string",
          "description": "Esempio di risposta compilata",
          "propertyOrder": 30
        }
      }
    },
    "target_utenti": {
      "allOf": [
        {
          "type": "object",
          "required": [
            "presenza doc preesistente"
          ],
          "properties": {
            "presenza doc preesistente": {
