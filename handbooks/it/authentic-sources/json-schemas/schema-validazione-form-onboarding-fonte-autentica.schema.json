{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/italia/eid-wallet-it-docs/handbooks/it/authentic-sources/json-schemas/schema-validazione-form-onboarding-fonte-autentica.schema.json",
  "$version": "1.2.2",
  "title": "Schema validazione Fonte Autentica",
  "description": "Schema di validazione per progettazione-caratteristiche-eaa.json. Ordine sezioni di primo livello: metadata, casi d'uso, pdnd metadata, request, data model (array di campi dataset), mappatura errori, mappatura stati, lista attributi (opzionale), assistenza. Nella sezione assistenza l'ordine è: referenti, canali, faq, testi informativi.",
  "type": "object",
  "required": [
    "metadata",
    "casi d'uso",
    "pdnd metadata",
    "request",
    "data model",
    "mappatura errori",
    "mappatura stati",
    "assistenza"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "required": [
        "nome ente titolare",
        "nome eaa",
        "versione"
      ],
      "properties": {
        "nome ente titolare": {
          "type": "string",
          "minLength": 1,
          "description": "Nome ufficiale dell'Ente titolare, es. MIT - Direzione generale per la Motorizzazione"
        },
        "nome eaa": {
          "type": "string",
          "minLength": 1,
          "description": "Nome ufficiale dell'EAA, es. Patente di guida"
        },
        "versione": {
          "type": "string",
          "const": "1.1.0",
          "description": "Versione del template di progettazione (valore fisso; aggiornare lo schema se si incrementa il template)."
        }
      },
      "title": "Denominazioni ufficiali per Ente e EAA"
    },
    "casi d'uso": {
      "$ref": "#/$defs/casi_d_uso"
    },
    "pdnd metadata": {
      "type": "object",
      "required": [
        "pdnd eservice id prod",
        "pdnd eservice id uat",
        "pdnd eservice name",
        "token type",
        "audit_rest_02_richiesto"
      ],
      "properties": {
        "pdnd eservice id prod": {
          "type": "string",
          "description": "UUID e-service PDND ambiente di produzione"
        },
        "pdnd eservice id uat": {
          "type": "string",
          "description": "UUID e-service PDND ambiente UAT/collaudo"
        },
        "pdnd eservice name": {
          "type": "string",
          "description": "Denominazione e-service su PDND"
        },
        "token type": {
          "type": "string",
          "description": "Tipo token di accesso (es. Bearer)"
        },
        "audit_rest_02_richiesto": {
          "type": "boolean",
          "description": "Indica se è richiesta conformità audit REST 02 (PDND)"
        }
      }
    },
    "request": {
      "type": "object",
      "required": [
        "parametri input"
      ],
      "properties": {
        "parametri input": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parametro_input"
          }
        }
      }
    },
    "data model": {
      "type": "array",
      "title": "Data Model",
      "description": "Elenco dei campi del dataset restituito dall'endpoint Fonte Autentica (contratto di response **1.0** come da Specifiche Tecniche; non è richiesto un campo `versione` nel JSON). Ogni elemento segue la definizione `data_model_campo`.",
      "items": {
        "$ref": "#/$defs/data_model_campo"
      }
    },
    "mappatura errori": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mappatura_errore"
      },
      "title": "Mappatura errori",
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 200
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 400
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 401
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 404
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 429
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 500
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "codice": {
                "const": 503
              }
            },
            "required": [
              "codice"
            ]
          },
          "minContains": 1,
          "maxContains": 1
        }
      ]
    },
    "mappatura stati": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/mappatura_stato"
            },
            {
              "properties": {
                "stato": {
                  "const": "Valido"
                },
                "descrizione": {
                  "const": "L'EAA è valido e può essere utilizzato"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/mappatura_stato"
            },
            {
              "oneOf": [
                {
                  "properties": {
                    "stato": {
                      "const": "Non Valido"
                    },
                    "descrizione": {
                      "const": "L'EAA non è più valido e dunque non può essere più utilizzato"
                    }
                  }
                },
                {
                  "properties": {
                    "stato": {
                      "const": "Non valido"
                    },
                    "descrizione": {
                      "const": "L'EAA non è più valido e dunque non può essere più utilizzato"
                    }
                  }
                }
              ]
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/mappatura_stato"
            },
            {
              "properties": {
                "stato": {
                  "const": "Sospeso"
                },
                "descrizione": {
                  "const": "L'EAA è sospeso e non può essere temporaneamente utilizzato"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/mappatura_stato"
            },
            {
              "properties": {
                "stato": {
                  "const": "Scaduto"
                },
                "descrizione": {
                  "const": "L'EAA ha superato la data di scadenza amministrativa e richiede rinnovo o nuova emissione"
                }
              }
            }
          ]
        }
      ],
      "title": "Mappatura stati"
    },
    "lista attributi": {
      "type": "array",
      "description": "Elenco opzionale per organizzare e descrivere gli attributi dell'EAA in vista (es. categorie, parametri, etichette UI); ogni riga segue lo stesso modello di `lista_attributi_riga`.",
      "items": {
        "$ref": "#/$defs/lista_attributi_riga"
      }
    },
    "assistenza": {
      "type": "object",
      "title": "Assistenza",
      "description": "Ordine di compilazione e presentazione: referenti, canali, FAQ, testi informativi.",
      "required": [
        "referenti",
        "canali",
        "faq",
        "testi informativi"
      ],
      "properties": {
        "referenti": {
          "title": "Referenti",
          "type": "array",
          "items": {
            "$ref": "#/$defs/referente_assistenza"
          },
          "prefixItems": [
            {
              "allOf": [
                {
                  "$ref": "#/$defs/referente_assistenza"
                },
                {
                  "properties": {
                    "ruolo": {
                      "const": "Referente ambito sistemistico"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/referente_assistenza"
                },
                {
                  "properties": {
                    "ruolo": {
                      "const": "Referente ambito applicativo"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/referente_assistenza"
                },
                {
                  "properties": {
                    "ruolo": {
                      "const": "Referente ambito assistenza"
                    }
                  }
                }
              ]
            }
          ]
        },
        "canali": {
          "title": "Canali",
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {
              "allOf": [
                {
                  "$ref": "#/$defs/canale_assistenza"
                },
                {
                  "properties": {
                    "tipo": {
                      "const": "Email assistenza"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/canale_assistenza"
                },
                {
                  "properties": {
                    "tipo": {
                      "const": "Numero telefonico"
                    }
                  }
                }
              ]
            },
            {
              "allOf": [
                {
                  "$ref": "#/$defs/canale_assistenza"
                },
                {
                  "properties": {
                    "tipo": {
                      "const": "Altro"
                    }
                  }
                }
              ]
            }
          ]
        },
        "faq": {
          "title": "FAQ",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/faq_item"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/campo_risposta"
              }
            }
          ]
        },
        "testi informativi": {
          "title": "Testi informativi",
          "type": "array",
          "items": {
            "$ref": "#/$defs/testo_informativo_item"
          }
        }
      }
    }
  },
  "$defs": {
    "data_model_campo": {
      "type": "object",
      "required": [
        "attestazione",
        "parametro",
        "descrizione",
        "nome campo",
        "esempio campo compilato",
        "obbligatorio",
        "tipologia",
        "note"
      ],
      "properties": {
        "attestazione": {
          "type": "string"
        },
        "parametro": {
          "type": "string"
        },
        "descrizione": {
          "type": "string"
        },
        "nome campo": {
          "type": "string"
        },
        "esempio campo compilato": {
          "type": "string"
        },
        "obbligatorio": {
          "type": "boolean",
          "description": "true se il campo è obbligatorio nella response; false se opzionale"
        },
        "tipologia": {
          "type": "string"
        },
        "lunghezza massima caratteri": {
          "type": "integer",
          "minimum": 0,
          "description": "Lunghezza massima in caratteri quando il dato è serializzato come stringa (es. tipologie testuali). Opzionale: omettere se non applicabile al tipo di attributo; in compilazione si consiglia di valorizzarlo per i campi con limite noto."
        },
        "note": {
          "type": "string"
        }
      }
    },
    "parametro_input": {
      "type": "object",
      "required": [
        "nome parametro",
        "descrizione",
        "nome campo",
        "esempio campo compilato",
        "obbligatorio",
        "tipologia",
        "lunghezza massima caratteri",
        "valori ammessi",
        "note"
      ],
      "properties": {
        "nome parametro": {
          "type": "string"
        },
        "descrizione": {
          "type": "string"
        },
        "nome campo": {
          "type": "string"
        },
        "esempio campo compilato": {
          "type": "string"
        },
        "obbligatorio": {
          "type": "boolean",
          "description": "true se il parametro è obbligatorio in input; false se opzionale"
        },
        "tipologia": {
          "type": "string"
        },
        "lunghezza massima caratteri": {
          "type": "integer",
          "minimum": 0,
          "description": "Lunghezza massima in caratteri (intero senza segno)"
        },
        "note": {
          "type": "string"
        },
        "valori ammessi": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Valori ammessi come elenco (es. enum)"
        }
      }
    },
    "mappatura_errore": {
      "type": "object",
      "required": [
        "codice",
        "esito",
        "applicabile",
        "causa",
        "azione utente",
        "note"
      ],
      "properties": {
        "codice": {
          "type": "integer",
          "enum": [
            200,
            400,
            401,
            403,
            404,
            405,
            406,
            408,
            409,
            410,
            413,
            414,
            421,
            429,
            431,
            451,
            500,
            501,
            503,
            540,
            541
          ],
          "description": "Codice HTTP o di dominio ammesso nel template (coppia codice/applicabile fissata dallo schema)."
        },
        "esito": {
          "type": "string"
        },
        "applicabile": {
          "type": "boolean",
          "description": "Obbligatoriamente true se il codice è tra quelli obbligatori del template (200, 400, 401, 404, 429, 500, 503); obbligatoriamente false per qualsiasi altro codice ammesso dall'enum (codici opzionali o futuri aggiunti all'enum ma non nella lista obbligatoria)."
        },
        "causa": {
          "type": "string",
          "description": "Causa dell'errore"
        },
        "azione utente": {
          "type": "string",
          "description": "Messaggio per l'utente in caso di errore"
        },
        "note": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "codice": {
                "enum": [
                  200,
                  400,
                  401,
                  404,
                  429,
                  500,
                  503
                ]
              }
            },
            "required": [
              "codice"
            ]
          },
          "then": {
            "properties": {
              "applicabile": {
                "const": true
              }
            }
          },
          "else": {
            "properties": {
              "applicabile": {
                "const": false
              }
            }
          }
        }
      ]
    },
    "mappatura_stato": {
      "type": "object",
      "required": [
        "stato",
        "descrizione",
        "applicabile",
        "azione utente",
        "note"
      ],
      "properties": {
        "stato": {
          "type": "string",
          "enum": [
            "Valido",
            "Non Valido",
            "Non valido",
            "Sospeso",
            "Scaduto"
          ],
          "description": "Valore letterale dello stato: **Non Valido** è il valore canonico (come in documentazione); è accettata anche la variante **Non valido** per compatibilità con JSON già esportati. Valori: Valido, Non Valido | Non valido, Sospeso, Scaduto."
        },
        "descrizione": {
          "type": "string",
          "description": "Causa del cambiamento di stato"
        },
        "applicabile": {
          "type": "boolean",
          "description": "true se lo stato si applica a questo EAA; false altrimenti"
        },
        "azione utente": {
          "type": "string",
          "description": "Messaggio per l'utente"
        },
        "messaggio": {
          "type": "string",
          "description": "Testo informativo aggiuntivo per la soluzione IT-Wallet (opzionale; se assente o vuoto non viene esposto alcun messaggio dedicato oltre a descrizione/azione utente)."
        },
        "note": {
          "type": "string"
        }
      }
    },
    "lista_attributi_riga": {
      "type": "object",
      "required": [
        "categoria",
        "parametro",
        "nome campo",
        "descrizione"
      ],
      "properties": {
        "categoria": {
          "type": "string"
        },
        "parametro": {
          "type": "string"
        },
        "nome campo": {
          "type": "string"
        },
        "descrizione": {
          "type": "string"
        }
      }
    },
    "campo_risposta": {
      "type": "object",
      "description": "Domanda, campo risposta (testo, booleano JSON o null in bozza) ed esempio guida; in anteprima/form l'ordine consigliato è domanda → risposta → esempio.",
      "required": [
        "domanda",
        "risposta",
        "esempio"
      ],
      "properties": {
        "domanda": {
          "type": "string",
          "description": "Testo della domanda",
          "propertyOrder": 10
        },
        "risposta": {
          "description": "Risposta dell'Ente: stringa (testo libero), booleano (domande sì/no) o null in bozza non ancora compilata.",
          "propertyOrder": 20,
          "type": [
            "string",
            "boolean",
            "null"
          ]
        },
        "esempio": {
          "type": "string",
          "description": "Esempio di risposta compilata (guida per l'Ente)",
          "propertyOrder": 30
        }
      }
    },
    "canale_assistenza": {
      "type": "object",
      "required": [
        "tipo",
        "dettaglio canale"
      ],
      "properties": {
        "tipo": {
          "type": "string",
          "enum": [
            "Email assistenza",
            "Numero telefonico",
            "Altro"
          ],
          "description": "Tipo di canale"
        },
        "note": {
          "type": "string",
          "description": "Note aggiuntive sul canale (opzionale)."
        },
        "dettaglio canale": {
          "type": "string",
          "description": "testo visualizzato dall'utente"
        },
        "esempio": {
          "type": "string"
        }
      },
      "if": {
        "properties": {
          "tipo": {
            "const": "Email assistenza"
          }
        },
        "required": [
          "tipo"
        ]
      },
      "then": {
        "properties": {
          "dettaglio canale": {
            "oneOf": [
              {
                "type": "string",
                "maxLength": 0
              },
              {
                "type": "string",
                "minLength": 1,
                "format": "email"
              }
            ]
          }
        }
      }
    },
    "referente_assistenza": {
      "type": "object",
      "required": [
        "ruolo",
        "nome",
        "cognome",
        "email",
        "telefono"
      ],
      "properties": {
        "ruolo": {
          "type": "string"
        },
        "nome": {
          "type": "string"
        },
        "cognome": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "oneOf": [
            {
              "maxLength": 0
            },
            {
              "minLength": 1,
              "format": "email"
            }
          ]
        },
        "telefono": {
          "type": "string",
          "oneOf": [
            {
              "maxLength": 0
            },
            {
              "minLength": 4,
              "pattern": "^[0-9+\\-\\s()]+$",
              "maxLength": 25
            }
          ]
        }
      }
    },
    "faq_item": {
      "type": "object",
      "description": "Voce FAQ: stessa struttura di campo_risposta (domanda, risposta, esempio; risposta stringa, booleano o null).",
      "required": [
        "domanda",
        "risposta",
        "esempio"
      ],
      "properties": {
        "domanda": {
          "type": "string",
          "description": "Testo della domanda",
          "propertyOrder": 10
        },
        "risposta": {
          "description": "Risposta dell'Ente: stringa (testo libero), booleano (domande sì/no) o null in bozza non ancora compilata.",
          "propertyOrder": 20,
          "type": [
            "string",
            "boolean",
            "null"
          ]
        },
        "esempio": {
          "type": "string",
          "description": "Esempio di risposta compilata",
          "propertyOrder": 30
        }
      }
    },
    "target_utenti": {
      "allOf": [
        {
          "type": "object",
          "required": [
            "presenza doc preesistente"
          ],
          "properties": {
            "presenza doc preesistente": {
              "$ref": "#/$defs/campo_risposta"
            },
            "utenti doc preesistente": {
              "$ref": "#/$defs/campo_risposta",
              "description": "Chi può richiedere il documento preesistente (nome chiave canonico, senza spazio finale)."
            },
            "utenti doc preesistente ": {
              "$ref": "#/$defs/campo_risposta",
              "description": "Deprecato: stessa semantica di «utenti doc preesistente»; accettato solo per compatibilità con moduli già esportati. Non usare nei nuovi file."
            },
            "utenti doc preesistente eaa": {
              "$ref": "#/$defs/campo_risposta"
            },
            "utenti eaa": {
              "$ref": "#/$defs/campo_risposta"
            },
            "documento fisico preesistente": {
              "$ref": "#/$defs/campo_risposta"
            },
            "chi puo richiedere": {
              "$ref": "#/$defs/campo_risposta"
            },
            "prerequisiti": {
              "$ref": "#/$defs/campo_risposta"
            },
            "volume rilascio": {
              "$ref": "#/$defs/campo_risposta"
            },
            "limitazioni estensioni": {
              "$ref": "#/$defs/campo_risposta"
            }
          }
        },
        {
          "not": {
            "allOf": [
              {
                "required": [
                  "utenti doc preesistente"
                ]
              },
              {
                "required": [
                  "utenti doc preesistente "
                ]
              }
            ]
          }
        }
      ]
    },
    "emissione_formato": {
      "type": "object",
      "required": [
        "prerequisiti eaa",
        "catalogo o touchpoint eaa",
        "modalita sincrona differita eaa",
        "eaa multipla o singola",
        "identificazione utente"
      ],
      "properties": {
        "prerequisiti eaa": {
          "$ref": "#/$defs/campo_risposta"
        },
        "prerequisiti possesso doc preesistente": {
          "$ref": "#/$defs/campo_risposta"
