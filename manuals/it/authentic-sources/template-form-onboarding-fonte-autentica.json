  "tipo_sezione": "documento_esistente",
  "sezione_documento_esistente": {
    "target_utenti": {
      "chi_puo_richiedere": {
        "domanda": "Chi può ad oggi richiedere il documento? Può ottenerlo l'intera popolazione italiana o solo alcuni cittadini?",
        "esempio": "Solo maggiorenni residenti in una specifica regione",
        "risposta": ""
      },
      "prerequisiti": {
        "domanda": "Esistono dei prerequisiti per richiedere il documento? Se sì, quali?",
        "esempio": "Necessario essere in possesso di altro documento, rispettare determinati criteri",
        "risposta": ""
      },
      "volume_rilascio": {
        "domanda": "Qual è il volume di rilascio del documento attuale?",
        "esempio": "200k Carte Europee della disabilità emesse in Italia",
        "risposta": ""
      },
      "limitazioni_estensioni": {
        "domanda": "L'EAA potrà essere richiesta da tutti coloro che attualmente possono richiedere il documento oppure sono previste limitazioni e/o estensioni? Se sì, quali?",
        "esempio": "Ambito geografico; disponibilità limitata ai dati successivi a una determinata data",
        "risposta": ""
      }
    },
    "emissione_formato": {
      "dominio": {
        "domanda": "A quale dominio appartiene il documento?",
        "esempio": "Istruzione, sanità",
        "risposta": ""
      },
      "interesse_pubblico": {
        "domanda": "Il documento è di interesse pubblico (Sì, No)? Perché?",
        "esempio": "Sì, perché rilasciato da ente pubblico",
        "risposta": ""
      },
      "canali_richiesta": {
        "domanda": "Tramite quali canali il cittadino può ad oggi richiedere il documento?",
        "esempio": "Sportello fisico, portale online",
        "risposta": ""
      },
      "richieste_fisico_vs_digitale": {
        "domanda": "Se possibile richiederlo anche online, quante sono le richieste fatte tramite canale fisico e quante tramite canale digitale?",
        "esempio": "70% fisico, 30% digitale",
        "risposta": ""
      },
      "formato_attuale": {
        "domanda": "In quale formato viene emesso ad oggi il documento? Card plastica, cartaceo, digitale?",
        "esempio": "Card plastica e versione digitale",
        "risposta": ""
      },
      "dettagli_digitale": {
        "domanda": "Se è già possibile ottenere il documento in formato digitale, fornisci dettagli sulle modalità di emissione",
        "esempio": "Scaricabile dal portale istituzionale",
        "risposta": ""
      },
      "possesso_documento": {
        "domanda": "Per ottenere l'EAA sarà necessario essere già in possesso del documento? Se sì, specificare motivazioni e condizioni",
        "esempio": "È sufficiente aver concluso l'iter di richiesta del documento",
        "risposta": ""
      },
      "catalogo_o_touchpoint": {
        "domanda": "L'utente potrà ottenere l'EAA solo dal catalogo di EAA del Wallet o anche da un touchpoint gestito dal tuo Ente?",
        "esempio": "Entrambi: catalogo e touchpoint Ente",
        "risposta": ""
      },
      "modalita_sincrona_differita": {
        "domanda": "L'utente potrà ottenere l'EAA in modalità sincrona (preferibile) o in modalità differita? Se differita, perché?",
        "esempio": "Sincrona",
        "risposta": ""
      },
      "variazioni_dati": {
        "domanda": "Sono previste variazioni tra i dati forniti per l'EAA e i dati attualmente presenti nel documento? Se sì, quali e perché?",
        "esempio": "Disponibilità limitata di dati storici",
        "risposta": ""
      },
      "eaa_univoca": {
        "domanda": "È prevista un'EAA univoca per ciascun soggetto o potranno essere emesse più EAA per lo stesso soggetto?",
        "esempio": "Una sola tessera sanitaria; molti titoli accademici",
        "risposta": ""
      },
      "identificazione_utente": {
        "domanda": "Per emettere l'EAA sarà necessario identificare l'utente (Sì, No)? Perché?",
        "esempio": "Sì, tramite Codice Fiscale",
        "risposta": ""
      }
    },
    "utilizzo": {
      "contesti_uso": {
        "domanda": "Quali sono gli attuali contesti d'uso del documento? Per cosa viene utilizzato principalmente?",
        "esempio": "Dimostrare possesso titoli professionali, accedere ad agevolazioni",
        "risposta": ""
      },
      "soggetti_verificatori": {
        "domanda": "Quali sono i principali soggetti che verificano ad oggi il documento?",
        "esempio": "Soggetti privati addetti alla sicurezza, operatori pubblici allo sportello",
        "risposta": ""
      },
      "verifica_validita": {
        "domanda": "Come è possibile verificare la validità del documento? QR code, Barcode, altri strumenti?",
        "esempio": "QR code, verifica de visu",
        "risposta": ""
      },
      "strumenti_verificatore": {
        "domanda": "Quali strumenti sono previsti da parte del verificatore per effettuare la verifica?",
        "esempio": "App per scan, verifica de visu",
        "risposta": ""
      },
      "utilizzo_continuo": {
        "domanda": "Il documento consente un utilizzo continuo o perde di validità non appena utilizzato?",
        "esempio": "Utilizzo continuo (tessera sanitaria); uso singolo (biglietto aereo)",
        "risposta": ""
      },
      "contesto_online_dal_vivo": {
        "domanda": "Il documento viene principalmente utilizzato online, dal vivo o in entrambi i contesti?",
        "esempio": "Entrambi: verifica presso sportelli e online",
        "risposta": ""
      },
      "tempo_validita": {
        "domanda": "Per quanto tempo è valido il documento? Validità uguale per tutti o variabile?",
        "esempio": "10 anni per tutti i cittadini",
        "risposta": ""
      },
      "rinnovo": {
        "domanda": "Il documento è rinnovabile? Se sì, cosa deve fare l'utente? Procedura digitale o uffici fisici?",
        "esempio": "Sì, presso uffici territoriali o online",
        "risposta": ""
      },
      "validita_europa": {
        "domanda": "Il documento può essere utilizzato solo in Italia o anche in Europa?",
        "esempio": "Solo Italia / Anche in Europa",
        "risposta": ""
      },
      "limitazioni_territoriali": {
        "domanda": "Il documento è valido su tutto il territorio o esistono limitazioni?",
        "esempio": "Solo in alcune Regioni",
        "risposta": ""
      },
      "eaa_tutti_contesti": {
        "domanda": "Sarà possibile utilizzare l'EAA in tutti i contesti in cui ad oggi è possibile utilizzare il documento?",
        "esempio": "Sì, con contesti remoto e di prossimità",
        "risposta": ""
      },
      "estensione_contesti": {
        "domanda": "L'EAA consentirà di estendere gli attuali contesti di utilizzo del documento?",
        "esempio": "Sì, nuovi casi d'uso per verifica remota",
        "risposta": ""
      }
    },
    "pagamento": {
      "gratuito_o_pagamento": {
        "domanda": "Il documento è gratuito o prevede un pagamento a carico dell'utente?",
        "esempio": "Gratuito",
        "risposta": ""
      },
      "modalita_pagamento": {
        "domanda": "Se prevede un pagamento, quali sono le modalità consentite?",
